# ── openclaude local Ollama configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required: tells openclaude to use an OpenAI-compatible backend
CLAUDE_CODE_USE_OPENAI=1

# Ollama's OpenAI-compatible endpoint (default, no change needed)
OPENAI_BASE_URL=http://localhost:11434/v1

# Model to use — must match exactly what `ollama list` shows
# Examples:
#   deepseek-coder-v2:16b
#   qwen3-coder
#   llama3.1:8b
OPENAI_MODEL=deepseek-coder-v2:16b

# No API key is needed for local Ollama.
# If openclaude requires the var to be set, use a placeholder:
# OPENAI_API_KEY=ollama
